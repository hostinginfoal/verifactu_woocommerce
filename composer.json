{
    "name": "infoal/verifactu-woocommerce",
    "description": "VeriFactu InFoAL plugin for WooCommerce",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "authors": [
        {
            "name": "InFoAL S.L.",
            "email": "hosting@infoal.com",
            "homepage": "https://www.infoal.com"
        }
    ],
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.0",
        "wp-coding-standards/wpcs": "^3.0"
    },
    "autoload": {
        "classmap": [
            "includes/",
            "admin/",
            "api/",
            "services/"
        ]
    },
    "scripts": {
        "lint": "phpcs --standard=WordPress ."
    }
}
